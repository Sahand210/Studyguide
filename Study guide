// ── HELPERS ──────────────────────────────────────────────────────────────
const D = s => { const d=new Date(s); d.setHours(0,0,0,0); return d; };
const TODAY = () => { const d=new Date(); d.setHours(0,0,0,0); return d; };
const daysBetween = (a,b) => Math.round((b-a)/86400000);
const fmt  = (d,o) => d.toLocaleDateString('en-GB', o||{day:'numeric',month:'long'});
const fmtS = d => d.toLocaleDateString('en-GB',{day:'numeric',month:'short'});
const dayN = d => d.toLocaleDateString('en-GB',{weekday:'long'});

function getTodayBlock(td) {
  // Phase 1?
  for (let p of PHASE1) if (D(p.date).getTime()===td.getTime()) return { phase:1, label:p.label, s:'General' };
  // Phase 2?
  for (let b of PHASE2_BLOCKS) if (td>=D(b.start) && td<=D(b.end)) return { phase:2, ...b };
  // Phase 3?
  for (let b of PHASE3_BLOCKS) if (td>=D(b.start) && td<=D(b.end)) return { phase:3, ...b };
  // Before start?
  if (td < D('2025-03-27')) return { phase:0, s:'Not started yet' };
  // After all exams?
  if (td > D('2025-07-02')) return { phase:4, s:'Done!' };
  return null;
}

function getDayNumber(td, block) {
  if (!block || block.phase===0 || block.phase===4) return 1;
  const start = D(block.start||'2025-03-27');
  // Count non-Friday days from start to td
  let d=new Date(start), count=0;
  while (d<=td) { if(d.getDay()!==5) count++; d.setDate(d.getDate()+1); }
  return count;
}

function getNextExam(td) {
  const allExams = [...PHASE2_BLOCKS].sort((a,b)=>D(a.exam)-D(b.exam));
  return allExams.find(e => D(e.exam) >= td);
}

// ── SPARKLES ─────────────────────────────────────────────────────────────
function sparkle(id) {
  const el=document.getElementById(id); if(!el) return;
  for(let i=0;i<12;i++){
    const s=document.createElement('div'); s.className='sparkle';
    s.style.left=Math.random()*100+'%'; s.style.top=Math.random()*100+'%';
    s.style.animationDelay=(Math.random()*3)+'s'; s.style.animationDuration=(2+Math.random()*2)+'s';
    el.appendChild(s);
  }
}


.hero-badge { display:inline-block; background:rgba(201,148,58,.2); border:1px solid rgba(201,148,58,.4); color:var(–gold-light); font-size:11px; font-weight:500; letter-spacing:2px; text-transform:uppercase; padding:6px 16px; border-radius:20px; margin-bottom:18px; position:relative; }

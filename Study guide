.tl-subj { font-weight:600; font-size:15px; color:var(–deep); }
.tl-meta { font-size:12px; color:var(–muted); margin-top:2px; }
.tl-range { font-size:11px; color:var(–gold); font-weight:500; margin-top:4px; }
.badge { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:600; margin-top:5px; }
.phase-tag { font-size:10px; font-weight:600; letter-spacing:1px; text-transform:uppercase; padding:2px 8px; border-radius:6px; margin-bottom:10px; display:inline-block; }

/* CHECKLIST */
.chk { display:flex; align-items:center; gap:12px; background:white; border-radius:12px; padding:13px 15px; margin-bottom:9px; box-shadow:0 2px 8px rgba(44,31,14,.05); cursor:pointer; transition:transform .1s; -webkit-tap-highlight-color:transparent; }

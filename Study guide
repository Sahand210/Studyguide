  const td = TODAY();
  sparkle('sp1');

  document.getElementById('today-date').textContent =
    td.toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric'});

  const block = getTodayBlock(td);
  const iconEl   = document.getElementById('today-icon');
  const nameEl   = document.getElementById('today-name');
  const detailEl = document.getElementById('today-detail');
  const msgEl    = document.getElementById('today-msg');
  const alertEl  = document.getElementById('today-alert');
  const rowEl    = document.getElementById('today-row');

  if (td.getDay()===5) {
    rowEl.style.background='#f0f7f0';
    iconEl.textContent='🌙'; nameEl.textContent="It's Friday — Rest Day";
    detailEl.textContent='No studying today. Recharge!';
    msgEl.textContent='Your brain needs rest too. Eat well, relax, come back stronger tomorrow. 💛';
    document.getElementById('sessions').innerHTML='<div class="card" style="text-align:center;padding:28px;color:var(--muted);font-style:italic;">It\'s a rest day 🌙<br>No sessions today.</div>';
  } else if (!block || block.phase===0) {
    iconEl.textContent='🌟'; nameEl.textContent='Journey starts tomorrow!';
    detailEl.textContent='27 March — General Study begins';
    msgEl.textContent="Get ready. Everything is planned and waiting for you. Let's do this. 💛";
    document.getElementById('sessions').innerHTML='';
  } else if (block.phase===4) {
    iconEl.textContent='🎉'; nameEl.textContent='All Exams Done!';
    detailEl.textContent='You made it — time to celebrate!';
    msgEl.textContent='Every single subject. Done. I told you you could do it. 💛';
    document.getElementById('sessions').innerHTML='';
  } else {
    const subj = block.s;
    const color = block.color||'#f5e6c8';
    rowEl.style.background=color+'44';
    iconEl.style.background=color+'66'; iconEl.textContent=block.icon||'📚';
    
    const dayNum = getDayNumber(td, block);
    const phaseLabel = block.phase===1 ? 'Phase 1 · General Study' : block.phase===2 ? 'Phase 2 · Review' : 'Phase 3 · Final Refresh';
    const phaseBg = block.phase===1 ? '#e8f0ff' : block.phase===2 ? '#fff3e0' : '#e8f5e0';
    const phaseCol = block.phase===1 ? '#5070c0' : block.phase===2 ? '#c9943a' : '#5a9a40';

    alertEl.innerHTML=`<div class="phase-pill" style="background:${phaseBg};color:${phaseCol}">${phaseLabel} · Day ${dayNum}</div><br>`;

    nameEl.textContent = block.phase===1 ? 'General Study' : (block.phase===3?'Final Refresh: ':'Study: ')+subj;

    if (block.exam) {
      const dLeft = daysBetween(td, D(block.exam));
      detailEl.textContent=`${subj} exam in ${dLeft} day${dLeft!==1?'s':''} — ${fmtS(D(block.exam))}`;
      if(dLeft<=2) alertEl.innerHTML+=`<div class="alert">⚡ Exam very soon!</div><br>`;
      else if(dLeft<=5) alertEl.innerHTML+=`<div class="alert">🔥 Almost there!</div><br>`;
    }

    msgEl.textContent=[
      `You're on day ${dayNum} of ${subj}. Stay focused — you're building something great. 💪`,
      `${subj} today. Morning session, break, afternoon session. One step at a time. 📚`,
      `Don't rush — understand it deeply. You've got this chapter. 🌟`,
    ][td.getDate()%3];

    // Sessions
    const mTasks = MORNING_TASKS[subj]||MORNING_TASKS['General'];
    const aTasks = AFTERNOON_TASKS[subj]||AFTERNOON_TASKS['General'];
    document.getElementById('sessions').innerHTML=`
      <div class="session">
        <div class="session-label">☀️ Morning Session · 9:00 – 12:00</div>
        ${mTasks.map(([time,text,topic])=>`
          <div class="task">
            <div class="task-time">${time}</div>
            <div class="task-info"><div class="task-text">${text}</div><div class="task-topic">${topic}</div></div>
          </div>`).join('')}
        <div class="task"><div class="task-time">11:30</div><div class="task-info"><div class="task-text">☕ Break — eat, rest, breathe</div><div class="task-topic">30 minutes away from books</div></div></div>
      </div>
      <div class="session">
        <div class="session-label">🌙 Afternoon Session · 2:00 – 5:30</div>
        ${aTasks.map(([time,text,topic])=>`
          <div class="task">
            <div class="task-time">${time}</div>
            <div class="task-info"><div class="task-text">${text}</div><div class="task-topic">${topic}</div></div>
          </div>`).join('')}
        <div class="task"><div class="task-time">5:30</div><div class="task-info"><div class="task-text">🌙 Done for today — well done!</div><div class="task-topic">Rest your brain, sleep before midnight</div></div></div>
      </div>`;

    // Buffer: show only if it's a phase3 block with only 1 day (tight)
    if (block.phase===3 && block.days===1) {
      document.getElementById('buffer-sec').style.display='block';
      document.getElementById('buffer-text').textContent=
        `Today is your only refresh day before the ${subj} exam. If you didn't cover everything, that's okay — focus on the most important topics and trust your earlier review. You already studied this. 💛`;
    }
  }

  // Countdown
  const next = getNextExam(td);
  if (next) {
    const d=daysBetween(td, D(next.exam));
    document.getElementById('countdown').innerHTML=`
      <div class="cd-num">${d}</div>
      <div class="cd-lbl">days until</div>
      <div class="cd-subj">${next.icon} ${next.s} exam — ${fmtS(D(next.exam))}</div>`;
  }

  // Progress
  const start=D('2025-03-27'), end=D('2025-07-02');
  const total=daysBetween(start,end);
  const passed=Math.max(0,Math.min(total,daysBetween(start,td)));
  document.getElementById('prog').style.width=Math.round(passed/total*100)+'%';
  document.getElementById('prog-pct').textContent=Math.round(passed/total*100)+'% done';

  // Quote
  document.getElementById('quote').textContent=QUOTES[td.getDate()%QUOTES.length];
}

// ── BUILD TIMELINE ─────────────────────────────────────────────────────────
function buildSchedule() {
  const td = TODAY();
  const container = document.getElementById('tl-container');

  const phaseHeader = (label, color, bg) =>
    `<div class="phase-tag" style="background:${bg};color:${color}">${label}</div>`;

  let html = '';

  // Phase 1
  html += phaseHeader('📌 Phase 1 — General Study · 27 Mar – 1 Apr','#5070c0','#e8f0ff');
  html += '<div class="tl" style="margin-bottom:20px;">';
  PHASE1.forEach((p,i)=>{
    const d=D(p.date); const done=td>d; const active=td.getTime()===d.getTime();
    html+=`<div class="tl-item" style="animation-delay:${i*.06}s">
      <div class="tl-dot" style="background:#e8f0ff">📚</div>
      <div class="tl-body ${active?'active':''} ${done?'done':''}">
        <div class="tl-subj">${p.label}</div>
        <div class="tl-meta">${fmt(d,{weekday:'long',day:'numeric',month:'long'})}</div>
        ${active?'<span class="badge" style="background:linear-gradient(135deg,#5070c0,#7090e0);color:white">📖 Today</span>':''}
      </div></div>`;
  });
  html += '</div>';

  // Phase 2
  html += phaseHeader('📌 Phase 2 — Review (furthest → closest) · Apr–Jun','#c9943a','#fff3e0');
  html += '<div class="tl" style="margin-bottom:20px;">';
  PHASE2_BLOCKS.forEach((b,i)=>{
    const s=D(b.start), e=D(b.end), exam=D(b.exam);
    const done=td>e; const active=!done&&td>=s&&td<=e;
    const dLeft=daysBetween(td,exam);
    const badge=done
      ?`<span class="badge" style="background:#e8f5e0;color:#5a9a40">✓ Done</span>`
      :active
        ?`<span class="badge" style="background:linear-gradient(135deg,#c9943a,#e8b96a);color:white">📖 Studying now · ${dLeft}d to exam</span>`
        :`<span class="badge" style="background:var(--warm);color:var(--muted)">Exam in ${dLeft}d</span>`;
    html+=`<div class="tl-item" style="animation-delay:${i*.06}s">
      <div class="tl-dot" style="background:${b.color}">${b.icon}</div>
      <div class="tl-body ${active?'active':''} ${done?'done':''}">
        <div class="tl-subj">${b.s}</div>
        <div class="tl-meta">Exam: ${fmt(exam,{day:'numeric',month:'long'})} · ${dayN(exam)}</div>
        <div class="tl-range">Review: ${fmtS(s)} → ${fmtS(e)} (${b.days} days)</div>
        ${badge}
      </div></div>`;
  });
  html += '</div>';

  // Phase 3
  html += phaseHeader('📌 Phase 3 — Final Refresh (gaps between exams)','#5a9a40','#e8f5e0');
  html += '<div class="tl" style="margin-bottom:8px;">';
  // Biology exam first (no refresh needed, it's the first)
  const bioExam = D('2025-06-11');
  const bioDone = td>bioExam; const bioActive = td.getTime()===bioExam.getTime();
  html+=`<div class="tl-item">
    <div class="tl-dot" style="background:#a8c5a0">🧬</div>
    <div class="tl-body ${bioDone?'done':''} ${bioActive?'active':''}">
      <div class="tl-subj">Biology Exam</div>
      <div class="tl-meta">${fmt(bioExam,{day:'numeric',month:'long',year:'numeric'})} · Wednesday</div>
      <div class="tl-range">No refresh needed — reviewed last in Phase 2 ✨</div>
      ${bioDone?'<span class="badge" style="background:#e8f5e0;color:#5a9a40">✓ Done</span>':''}
    </div></div>`;

  PHASE3_BLOCKS.forEach((b,i)=>{
    const s=D(b.start), e=D(b.end), exam=D(b.exam);
    const done=td>exam; const active=!done&&td>=s&&td<=e;
    const dLeft=daysBetween(td,exam);
    const badge=done
      ?`<span class="badge" style="background:#e8f5e0;color:#5a9a40">✓ Done</span>`
      :active
        ?`<span class="badge" style="background:linear-gradient(135deg,#5a9a40,#7aba60);color:white">🔁 Refreshing now</span>`
        :`<span class="badge" style="background:var(--warm);color:var(--muted)">Exam in ${dLeft}d</span>`;
    html+=`<div class="tl-item" style="animation-delay:${i*.06}s">
      <div class="tl-dot" style="background:${b.color}">${b.icon}</div>
      <div class="tl-body ${active?'active':''} ${done?'done':''}">
        <div class="tl-subj">${b.s} — Final Refresh + Exam</div>
        <div class="tl-meta">Exam: ${fmt(exam,{day:'numeric',month:'long'})} · ${dayN(exam)}</div>
        <div class="tl-range">Refresh: ${fmtS(s)} → ${fmtS(e)} (${b.days} day${b.days>1?'s':''})</div>
        ${badge}
      </div></div>`;
  });
  html += '</div>';

  container.innerHTML = html;
}

// ── BUILD CHECKLIST ────────────────────────────────────────────────────────
function buildChecklist() {
  const td=TODAY();
  const block=getTodayBlock(td);
  const dateKey='chk_'+td.toISOString().slice(0,10);
  const stored=JSON.parse(localStorage.getItem(dateKey)||'{}');

  let tasks=[];
  if(td.getDay()===5) {
    tasks=['🌙 Rest and relax','🍽 Eat a proper meal','😴 Sleep early tonight','📵 Limit screens before bed','💆‍♀️ Do something you enjoy'];
  } else if(block && (block.phase===1||block.phase===2||block.phase===3)) {
    const subj=block.s;
    const m=MORNING_TASKS[subj]||MORNING_TASKS['General'];
    const a=AFTERNOON_TASKS[subj]||AFTERNOON_TASKS['General'];
    tasks=[
      ...m.map(([,t])=>t),
      '☕ Take your break (30 min)',
      ...a.map(([,t])=>t),
      '💧 Drink water throughout the day',
      '🍱 Eat a proper meal',
      '🛏 Sleep before midnight',
    ];
  } else {
    tasks=['📚 Get ready for tomorrow!','🗂 Organize your notes','😴 Sleep early'];
  }

  document.getElementById('checklist').innerHTML=tasks.map((t,i)=>{
    const key='t'+i, c=stored[key]||false;
    return `<div class="chk ${c?'done':''}" onclick="toggleChk(this,'${key}','${dateKey}')">
      <div class="chk-box">${c?'<span style="color:white;font-size:13px">✓</span>':''}</div>
      <div class="chk-lbl">${t}</div></div>`;
  }).join('');
}

function toggleChk(el,key,dateKey){
  el.classList.toggle('done');
  const c=el.classList.contains('done');
  el.querySelector('.chk-box').innerHTML=c?'<span style="color:white;font-size:13px">✓</span>':'';
  const s=JSON.parse(localStorage.getItem(dateKey)||'{}');
  s[key]=c; localStorage.setItem(dateKey,JSON.stringify(s));
}


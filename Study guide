.chk.done .chk-box { background:var(–gold); border-color:var(–gold); }
.chk-lbl { font-size:14px; color:var(–text); }
.chk.done .chk-lbl { text-decoration:line-through; color:var(–muted); }

/* BUFFER */
.buffer-card { background:linear-gradient(135deg,#fff8ee,#fdf0d8); border:2px dashed var(–gold-light); border-radius:16px; padding:18px 20px; margin-bottom:12px; }
.buffer-title { font-weight:600; color:var(–deep); font-size:14px; margin-bottom:6px; }
.buffer-text { font-size:13px; color:var(–muted); line-height:1.6; }

/* QUOTE */
.quote-card { background:linear-gradient(135deg,#2c1f0e,#4a3018); border-radius:20px; padding:28px 24px; text-align:center; position:relative; overflow:hidden; }

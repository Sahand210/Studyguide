.sec { max-width:480px; margin:20px auto 0; padding:0 20px; }
.card { background:white; border-radius:16px; padding:20px; box-shadow:0 4px 20px rgba(44,31,14,.08); border:1px solid rgba(201,148,58,.1); }
.card.hi { border:2px solid var(–gold); box-shadow:0 6px 28px rgba(201,148,58,.2); }
.lbl { font-size:10px; font-weight:500; letter-spacing:2px; text-transform:uppercase; color:var(–muted); margin-bottom:6px; }
.sec-title { font-family:‘Playfair Display’,serif; font-size:19px; color:var(–deep); margin-bottom:14px; }

/* TODAY PULL */
.pull { max-width:480px; margin:-28px auto 0; padding:0 20px; position:relative; z-index:10; animation:slideUp .5s ease both; }
@keyframes slideUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
.subj-row { display:flex; align-items:center; gap:14px; border-radius:14px; padding:14px; margin-bottom:12px; }
.subj-icon { width:46px; height:46px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:24px; flex-shrink:0; }
.subj-name { font-family:‘Playfair Display’,serif; font-size:18px; color:var(–deep); font-weight:700; }
.subj-detail { font-size:12px; color:var(–muted); margin-top:2px; }
.msg { font-size:13px; color:var(–muted); font-style:italic; line-height:1.7; border-left:3px solid var(–gold-light); padding-left:12px; }
.alert { display:inline-flex; align-items:center; gap:6px; background:linear-gradient(135deg,#c9943a,#e8b96a); color:white; font-size:11px; font-weight:600; padding:5px 12px; border-radius:20px; margin-bottom:10px; }
.phase-pill { display:inline-flex; align-items:center; gap:5px; font-size:11px; font-weight:600; padding:4px 12px; border-radius:20px; margin-bottom:10px; }

/* PROGRESS */
.prog-wrap { background:var(–warm); border-radius:10px; height:10px; overflow:hidden; margin:10px 0 6px; }
.prog-fill { height:100%; border-radius:10px; background:linear-gradient(90deg,var(–gold),var(–gold-light)); transition:width 1.2s ease; }
.prog-stats { display:flex; justify-content:space-between; font-size:12px; color:var(–muted); }

/* COUNTDOWN */
.cd { text-align:center; padding:10px 0; }
.cd-num { font-family:‘Playfair Display’,serif; font-size:42px; font-weight:700; color:var(–gold); line-height:1; }

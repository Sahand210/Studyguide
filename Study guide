// Phase 3: refresh gaps between exams
const PHASE3_BLOCKS = [
  { s:'Kurdish',      icon:'📖', color:'#c4b4d8', exam:'2025-06-14', start:'2025-06-12', end:'2025-06-12', days:1 },
  { s:'Math',         icon:'📐', color:'#a8bfd8', exam:'2025-06-18', start:'2025-06-15', end:'2025-06-17', days:3 },
  { s:'Arabic & Ayn', icon:'✍️', color:'#e8c4a0', exam:'2025-06-21', start:'2025-06-19', end:'2025-06-19', days:1 },
  { s:'Chemistry',    icon:'⚗️', color:'#e8b4b8', exam:'2025-06-25', start:'2025-06-22', end:'2025-06-24', days:3 },
  { s:'English',      icon:'🔤', color:'#c4d8a8', exam:'2025-06-28', start:'2025-06-26', end:'2025-06-26', days:1 },

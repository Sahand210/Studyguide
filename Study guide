.cd-subj { font-size:13px; color:var(–text); font-weight:500; margin-top:8px; }

/* TASKS */
.task { display:flex; align-items:flex-start; gap:12px; padding:11px 0; border-bottom:1px solid var(–warm); }
.task:last-child { border-bottom:none; }
.task-time { font-size:11px; font-weight:600; color:var(–gold); min-width:52px; margin-top:2px; }
.task-info { flex:1; }
.task-text { font-size:13px; color:var(–text); line-height:1.5; }
.task-topic { font-size:11px; color:var(–muted); margin-top:2px; }

/* TIMELINE */
.tl { position:relative; }
.tl::before { content:’’; position:absolute; left:20px; top:0; bottom:0; width:2px; background:linear-gradient(to bottom,var(–gold),transparent); }
.tl-item { display:flex; gap:16px; margin-bottom:14px; animation:fadeIn .4s ease both; }
@keyframes fadeIn { from{opacity:0;transform:translateX(-8px)} to{opacity:1;transform:translateX(0)} }
.tl-dot { width:42px; height:42px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; z-index:1; border:3px solid white; box-shadow:0 2px 8px rgba(44,31,14,.1); }
